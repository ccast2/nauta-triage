# Copy to .env and fill in your OpenAI API key.
# docker-compose automatically loads variables from .env in this directory.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
LLM_ENABLED=true

# Host ports (override if any clash with other apps running locally)
APP_HOST_PORT=18080
DB_HOST_PORT=15432
CARRIER_PORTAL_HOST_PORT=19001
TERMINAL_FEED_HOST_PORT=19002
WEB_HOST_PORT=13000

